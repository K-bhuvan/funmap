# Copy to local.properties (gitignored) and set your machine paths.

# Android SDK (Android Studio sets this automatically when you sync.)
# sdk.dir=/Users/you/Library/Android/sdk

# Backend reachable from the emulator (10.0.2.2 = host loopback).
# For a physical device, use your PC's LAN IP, e.g. http://192.168.1.50:8080/
ASKMAPS_BACKEND_URL=http://10.0.2.2:8080/

# Optional. Comma-separated browser origins for CORS. In production, set this
# explicitly (defaults are only applied in development).
# CORS_ORIGIN=http://localhost:3000,https://app.example.com

# Optional. Set to 1 when the app sits behind a reverse proxy (rate limiting / IP).
# TRUST_PROXY=1

# Required for production Nominatim use: descriptive User-Agent with contact (see OSM policy).
# NOMINATIM_USER_AGENT=AskMaps/1.0 (you@example.com)
